<?xml version="1.0"?>
<!-- Import the xacro library -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Include the inertial macro -->
    <xacro:include filename="inertial_macros.xacro" />

    <!-- **********Define the material color********** -->
    <material name="white">
        <color rgba="1.0 1.0 1.0 1.0"/>
    </material>
    <material name="orange">
        <color rgba="1.0 0.3 0.1 1.0"/>
    </material>
    <material name="blue">
        <color rgba="0.2 0.2 1.0 1.0"/>
    </material>
    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>
    <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
    </material>


    <!-- **********Coding here, create the link and joint********** -->
    <!-- Create the base_link. (Which it was on the middle of 2 wheels)-->
    <link name="base_link">
        
    </link>

    <!-- Create the chassis_joint (Which) -->
    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis_link"/>
        <origin xyz="-0.1 0.0 0.0"/>
    </joint>

    <!-- Create the chassis_link -->
    <link name="chassis_link">
        <visual>
            <origin xyz="0.15 0.0 0.075" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.3 0.3 0.15"/>
            </geometry>
            <material name="white"/>
        </visual>
        <collision>
            <origin xyz="0.15 0.0 0.075" rpy="0.0 0.0 0.0"/>
            <geometry>
                <box size="0.3 0.3 0.15"/>
            </geometry>
        </collision>
        <xacro:inertial_box mass="0.5" x="0.3" y="0.3" z="0.15">
            <origin xyz="0.15 0.0 0.075" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_box>
    </link>

    <!-- Add color in the chassis_link in gazebo -->
    <gazebo reference="chassis_link" >
        <material>Gazebo/White</material>
    </gazebo>

    <!-- Create the left wheel joint -->
    <joint name="left_wheel_joint" type="continuous">
        <origin xyz="0.0 0.175 0.0" rpy="-${pi/2} 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <axis xyz="0.0 0.0 1.0"/>
    </joint>

    <!-- Create the left wheel link -->
    <link name="left_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.05">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- Add color in the left_wheel_link in gazebo -->
    <gazebo reference="left_wheel_link" >
        <material>Gazebo/Blue</material>
    </gazebo>

    <!-- Create the right wheel joint -->
    <joint name="right_wheel_joint" type="continuous">
        <origin xyz="0.0 -0.175 0.0" rpy="${pi/2} 0.0 0.0"/>
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <axis xyz="0.0 0.0 -1.0"/>
    </joint>

    <!-- Create the right wheel link -->
    <link name="right_wheel_link">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
            <material name="blue"/>
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.05" length="0.04"/>
            </geometry>
        </collision>
        <xacro:inertial_cylinder mass="0.1" length="0.04" radius="0.05">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_cylinder>
    </link>

    <!-- Add color in the right_wheel_link in gazebo -->
    <gazebo reference="right_wheel_link" >
        <material>Gazebo/Blue</material>
    </gazebo>

    <!-- Create the caster joint -->
    <joint name="caster_joint" type="fixed">
        <origin xyz="0.24 0.0 0.0" rpy="0.0 0.0 0.0"/>
        <parent link="chassis_link"/>
        <child link="caster_link"/>
    </joint>

    <!-- Create the caster link -->
    <link name="caster_link">
        <visual>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <geometry>
                <sphere radius="0.05"/>
            </geometry>
        </collision>
        <xacro:inertial_sphere mass="0.1" radius="0.05">
            <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
        </xacro:inertial_sphere>
    </link>

    <!-- Add color in the caster_link in gazebo -->
    <gazebo reference="caster_link" >
        <material>Gazebo/Black</material>
        <!-- Set the friction in gazebo to be slip -->
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>

</robot>